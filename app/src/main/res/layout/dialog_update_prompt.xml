<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="420dp"
    android:layout_height="wrap_content"
    android:background="@drawable/home_dialog_surface"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/home_news_badge"
        android:fontFamily="@font/montserrat_bold"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="Atualizacao"
        android:textAllCaps="true"
        android:textColor="@android:color/white"
        android:textSize="9sp" />

    <TextView
        android:id="@+id/update_prompt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/montserrat_black"
        android:text="Atualizacao de dados encontrada"
        android:textColor="@android:color/white"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/update_prompt_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="Baixe a versao nova agora para entrar com os arquivos corretos. Se voce ja atualizou manualmente, pode ignorar."
        android:textColor="#D3C7E3"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/update_prompt_secondary"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/home_action_secondary"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="120dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Agora nao"
            android:textColor="@android:color/white"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/update_prompt_primary"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/home_server_select_button"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="140dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Atualizar"
            android:textColor="@android:color/white"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
