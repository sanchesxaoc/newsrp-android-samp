<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/home_server_option_default"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/item_server_status"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/server_status_dot_loading" />

        <TextView
            android:id="@+id/item_server_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/montserrat_bold"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/launcher_badge_gold"
            android:fontFamily="@font/montserrat_bold"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="SALVO"
            android:textAllCaps="true"
            android:textColor="@color/launcher_text_secondary"
            android:textSize="7sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/item_server_players"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/montserrat_bold"
        android:textColor="@color/launcher_text_secondary"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/item_server_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/montserrat_medium"
        android:textColor="@color/launcher_text_muted"
        android:textSize="8.5sp" />

    <TextView
        android:id="@+id/item_server_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/launcher_field_surface_dark"
        android:fontFamily="@font/montserrat_medium"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:textColor="#D8E2EC"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_server_select_action"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/home_server_select_button"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="96dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Selecionar"
            android:textColor="@android:color/white"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/item_server_remove_action"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/home_action_text_button"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="90dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Remover"
            android:textColor="@android:color/white"
            android:textSize="9sp" />
    </LinearLayout>

</LinearLayout>
