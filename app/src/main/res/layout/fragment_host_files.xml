<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="104dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_panel_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/home_news_badge"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                    android:text="Arquivos"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="8sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/launcher_badge_outline"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                    android:text="GERENCIADOR"
                        android:textAllCaps="true"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="7.5sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/montserrat_black"
                    android:text="Arquivos do servidor"
                    android:textColor="@android:color/white"
                    android:textSize="21sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:maxWidth="720dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:lineSpacingExtra="3dp"
                    android:text="Navegue, crie, importe e organize a base do host em uma tela de explorador."
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="9.5sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/file_browser_toolbar_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Endereco atual"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/host_files_current_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/launcher_field_surface_dark"
                        android:fontFamily="monospace"
                        android:paddingStart="12dp"
                        android:paddingTop="11dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="11dp"
                        android:textColor="#D8E2EC"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/host_files_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_host_files_back"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_ghost_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Voltar"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_host_files_root"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_ghost_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Raiz"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_host_refresh_files"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_secondary_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Atualizar"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_host_files_import"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_primary_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Importar"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_host_files_new_folder"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_secondary_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Nova pasta"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_host_files_new_file"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_secondary_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Novo arquivo"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/file_browser_list_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Conteudo desta pasta"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Itens em formato de explorador: pastas primeiro, depois arquivos, com caminhos e acoes compactas."
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="8.6sp" />

                    <TextView
                        android:id="@+id/host_files_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/host_dashboard_subtle_note"
                        android:fontFamily="@font/montserrat_medium"
                        android:padding="16dp"
                        android:text="Esta pasta ainda nao tem arquivos nem subpastas."
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="10sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/host_files_list_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
