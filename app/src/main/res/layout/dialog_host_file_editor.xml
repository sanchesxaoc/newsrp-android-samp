<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/home_panel_surface"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/home_news_badge"
            android:fontFamily="@font/montserrat_bold"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="Arquivo"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/dialog_host_file_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/montserrat_black"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/dialog_host_file_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/montserrat_medium"
            android:textColor="@color/launcher_text_secondary"
            android:textSize="8.5sp" />

        <EditText
            android:id="@+id/dialog_host_file_editor"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/launcher_console_surface"
            android:fontFamily="monospace"
            android:gravity="start|top"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:scrollbars="vertical"
            android:textColor="@android:color/white"
            android:textSize="9sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dialog_host_file_cancel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/home_action_text_button"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Cancelar"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/dialog_host_file_save"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/home_server_select_button"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:text="Salvar"
                android:textColor="@android:color/white"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
