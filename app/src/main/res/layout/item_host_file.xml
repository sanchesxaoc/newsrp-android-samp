<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/host_file_item_surface"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/file_browser_row_surface"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/host_file_icon_surface"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/file_browser_icon_surface_folder">

            <ImageView
                android:id="@+id/host_file_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_browser_folder" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/host_file_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/montserrat_bold"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/host_file_type_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/file_browser_chip_folder"
                    android:fontFamily="@font/montserrat_bold"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp"
                    android:text="PASTA"
                    android:textAllCaps="true"
                    android:textColor="@android:color/white"
                    android:textSize="7.2sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/host_file_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/montserrat_medium"
                android:textColor="@color/launcher_text_secondary"
                android:textSize="8.8sp" />

            <TextView
                android:id="@+id/host_file_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:fontFamily="monospace"
                android:textColor="#92A8BE"
                android:textSize="8.3sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/host_file_open_action"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/file_browser_primary_action"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="96dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="Abrir"
            android:textColor="@android:color/white"
            android:textSize="8.3sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/host_file_rename_action"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/file_browser_ghost_action"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="94dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Renomear"
            android:textColor="@android:color/white"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/host_file_delete_action"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/file_browser_secondary_action"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            android:minWidth="82dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Excluir"
            android:textColor="@android:color/white"
            android:textSize="8sp" />
    </LinearLayout>

</LinearLayout>
