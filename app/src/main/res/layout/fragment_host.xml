<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="108dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_panel_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/home_news_badge"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="Host"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="8sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/launcher_badge_outline"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="CONTROL CENTER"
                        android:textAllCaps="true"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="7.5sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/montserrat_black"
                    android:text="Host local"
                    android:textColor="@android:color/white"
                    android:textSize="21sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:maxWidth="720dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:lineSpacingExtra="3dp"
                    android:text="Controle o servidor, veja os enderecos de entrada e acesse arquivos sem sair do launcher."
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="9.5sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/host_dashboard_hero_surface"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/host_status_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/host_dashboard_status_badge"
                            android:fontFamily="@font/montserrat_bold"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:text="BASE"
                            android:textAllCaps="true"
                            android:textColor="@android:color/white"
                            android:textSize="7.8sp" />

                        <TextView
                            android:id="@+id/host_status_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_black"
                            android:text="Host local em preparacao"
                            android:textColor="@android:color/white"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/host_status_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/host_dashboard_endpoint_surface"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Base local"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/host_workspace_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/montserrat_medium"
                                android:textColor="@color/launcher_text_muted"
                                android:textSize="8.5sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:background="@drawable/host_dashboard_endpoint_surface"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Loopback do launcher"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/host_loopback_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/montserrat_medium"
                                android:textColor="@color/launcher_text_muted"
                                android:textSize="8.5sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/button_boot_host"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/file_browser_primary_action"
                        android:fontFamily="@font/montserrat_bold"
                        android:gravity="center"
                        android:text="Ligar host"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/button_stop_local_host"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/file_browser_secondary_action"
                        android:fontFamily="@font/montserrat_bold"
                        android:gravity="center"
                        android:text="Desligar host"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/host_action_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/host_dashboard_subtle_note"
                    android:fontFamily="@font/montserrat_medium"
                    android:lineSpacingExtra="2dp"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/launcher_text_muted"
                    android:textSize="8.7sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/file_browser_list_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Entradas e rede"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Escolha uma opcao. O host e unico; so o acesso remoto abre tunel pela internet."
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="8.6sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/host_local_access_option"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/host_dashboard_endpoint_surface"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Mesmo aparelho"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/host_local_address_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:fontFamily="monospace"
                                android:textColor="#EAF3FF"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/host_lan_access_option"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:background="@drawable/host_dashboard_endpoint_surface"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Mesma rede"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/host_lan_address_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:fontFamily="monospace"
                                android:textColor="#EAF3FF"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/host_remote_access_option"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:background="@drawable/host_dashboard_endpoint_surface"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Acesso remoto"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <TextView
                                android:id="@+id/host_remote_access_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:fontFamily="monospace"
                                android:textColor="#EAF3FF"
                                android:textSize="9.2sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/host_join_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/host_dashboard_subtle_note"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingExtra="2dp"
                        android:padding="14dp"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="8.8sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_host_copy_lan"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_primary_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Mesmo aparelho"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_host_refresh_join"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_ghost_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Mesma rede"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_host_pinggy"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/file_browser_secondary_action"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Acesso remoto"
                            android:textColor="@android:color/white"
                            android:textSize="8.4sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/file_browser_list_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Arquivos do servidor"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingExtra="2dp"
                        android:text="Abra a estrutura do host como gerenciador de arquivos, entre nas pastas, edite configs, envie gamemodes e organize tudo dentro do APK."
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="8.8sp" />

                    <TextView
                        android:id="@+id/button_open_server_files"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/file_browser_primary_action"
                        android:fontFamily="@font/montserrat_bold"
                        android:gravity="center"
                        android:text="Abrir gerenciador de arquivos do servidor"
                        android:textColor="@android:color/white"
                        android:textSize="9.4sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
