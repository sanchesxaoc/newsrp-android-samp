<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="104dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_panel_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/home_news_badge"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="Dev"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="8sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/launcher_badge_outline"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                    android:text="WORKBENCH"
                        android:textAllCaps="true"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="7.5sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/montserrat_black"
                    android:text="Ferramentas do servidor"
                    android:textColor="@android:color/white"
                    android:textSize="21sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:maxWidth="760dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:lineSpacingExtra="3dp"
                    android:text="Edite configuracoes, crie arquivos, gere backup e acompanhe logs do host."
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="9.5sp" />

                <TextView
                    android:id="@+id/workbench_status_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/launcher_console_surface"
                    android:fontFamily="@font/montserrat_medium"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/file_browser_list_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Configurador visual do servidor"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Esses campos atualizam o server.cfg e o config.json juntos."
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="8.7sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Nome do servidor"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <EditText
                                android:id="@+id/workbench_hostname_input"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/launcher_field_surface_dark"
                                android:fontFamily="@font/montserrat_bold"
                                android:hint="News RP Local Host"
                                android:imeOptions="actionNext|flagNoExtractUi"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:singleLine="true"
                                android:textColor="@android:color/white"
                                android:textColorHint="@color/launcher_text_muted"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Website"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <EditText
                                android:id="@+id/workbench_website_input"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/launcher_field_surface_dark"
                                android:fontFamily="@font/montserrat_bold"
                                android:hint="localhost"
                                android:imeOptions="actionNext|flagNoExtractUi"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:singleLine="true"
                                android:textColor="@android:color/white"
                                android:textColorHint="@color/launcher_text_muted"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Language"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <EditText
                                android:id="@+id/workbench_language_input"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/launcher_field_surface_dark"
                                android:fontFamily="@font/montserrat_bold"
                                android:hint="pt-BR"
                                android:imeOptions="actionNext|flagNoExtractUi"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:singleLine="true"
                                android:textColor="@android:color/white"
                                android:textColorHint="@color/launcher_text_muted"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Max players"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <EditText
                                android:id="@+id/workbench_max_players_input"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/launcher_field_surface_dark"
                                android:fontFamily="@font/montserrat_bold"
                                android:hint="32"
                                android:imeOptions="actionNext|flagNoExtractUi"
                                android:inputType="number"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:singleLine="true"
                                android:textColor="@android:color/white"
                                android:textColorHint="@color/launcher_text_muted"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Script principal"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <EditText
                                android:id="@+id/workbench_main_script_input"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/launcher_field_surface_dark"
                                android:fontFamily="@font/montserrat_bold"
                                android:hint="blank"
                                android:imeOptions="actionNext|flagNoExtractUi"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:singleLine="true"
                                android:textColor="@android:color/white"
                                android:textColorHint="@color/launcher_text_muted"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Senha (opcional)"
                                android:textColor="@android:color/white"
                                android:textSize="9sp" />

                            <EditText
                                android:id="@+id/workbench_password_input"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/launcher_field_surface_dark"
                                android:fontFamily="@font/montserrat_bold"
                                android:hint="Deixe vazio para livre"
                                android:imeOptions="actionNext|flagNoExtractUi"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:singleLine="true"
                                android:textColor="@android:color/white"
                                android:textColorHint="@color/launcher_text_muted"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Map name (opcional)"
                            android:textColor="@android:color/white"
                            android:textSize="9sp" />

                        <EditText
                            android:id="@+id/workbench_map_name_input"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/launcher_field_surface_dark"
                            android:fontFamily="@font/montserrat_bold"
                            android:hint="Los Santos / Roleplay / Drift"
                            android:imeOptions="actionDone|flagNoExtractUi"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:textColor="@android:color/white"
                            android:textColorHint="@color/launcher_text_muted"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/launcher_stat_tile"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Announce"
                                android:textColor="@color/launcher_text_primary"
                                android:textSize="9sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/workbench_announce_switch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/launcher_stat_tile"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Query"
                                android:textColor="@color/launcher_text_primary"
                                android:textSize="9sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/workbench_query_switch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/launcher_stat_tile"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="LAN mode"
                                android:textColor="@color/launcher_text_primary"
                                android:textSize="9sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/workbench_lan_mode_switch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/button_workbench_save_settings"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/home_server_select_button"
                        android:fontFamily="@font/montserrat_bold"
                        android:gravity="center"
                        android:minWidth="176dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="Salvar configuracoes"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/file_browser_list_surface"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Criacao rapida"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Crie arquivos base do servidor sem precisar sair para o gerenciador."
                            android:textColor="@color/launcher_text_secondary"
                            android:textSize="8.7sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/button_workbench_new_gamemode"
                                android:layout_width="0dp"
                                android:layout_height="38dp"
                                android:layout_weight="1"
                                android:background="@drawable/home_server_select_button"
                                android:fontFamily="@font/montserrat_bold"
                                android:gravity="center"
                                android:text="Nova GM"
                                android:textColor="@android:color/white"
                                android:textSize="8.8sp" />

                            <TextView
                                android:id="@+id/button_workbench_new_include"
                                android:layout_width="0dp"
                                android:layout_height="38dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/home_action_secondary"
                                android:fontFamily="@font/montserrat_bold"
                                android:gravity="center"
                                android:text="Novo include"
                                android:textColor="@android:color/white"
                                android:textSize="8.8sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/button_workbench_new_scriptfile"
                                android:layout_width="0dp"
                                android:layout_height="38dp"
                                android:layout_weight="1"
                                android:background="@drawable/home_action_text_button"
                                android:fontFamily="@font/montserrat_bold"
                                android:gravity="center"
                                android:text="Novo scriptfile"
                                android:textColor="@android:color/white"
                                android:textSize="8.8sp" />

                            <TextView
                                android:id="@+id/button_workbench_new_config"
                                android:layout_width="0dp"
                                android:layout_height="38dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:background="@drawable/home_action_text_button"
                                android:fontFamily="@font/montserrat_bold"
                                android:gravity="center"
                                android:text="Novo cfg"
                                android:textColor="@android:color/white"
                                android:textSize="8.8sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/workbench_resource_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/launcher_console_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:padding="12dp"
                            android:text="A criacao rapida gera templates basicos para voce continuar no Editor ou em Arquivos."
                            android:textColor="@color/launcher_text_secondary"
                            android:textSize="8.8sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/file_browser_list_surface"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Atalhos dev"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Pule direto para o ponto do launcher onde voce vai continuar a mexer."
                            android:textColor="@color/launcher_text_secondary"
                            android:textSize="8.7sp" />

                        <TextView
                            android:id="@+id/button_workbench_open_editor"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Abrir editor"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_workbench_open_files"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Abrir arquivos"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_workbench_open_host"
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/home_action_text_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Abrir host"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/file_browser_list_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Backups e logs"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/workbench_backup_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/launcher_field_surface_dark"
                        android:fontFamily="@font/montserrat_medium"
                        android:padding="14dp"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_workbench_create_backup"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:minWidth="156dp"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Criar backup .zip"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_workbench_refresh_logs"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:minWidth="120dp"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Atualizar"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/workbench_logs_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/launcher_console_surface"
                        android:fontFamily="monospace"
                        android:minHeight="160dp"
                        android:padding="14dp"
                        android:textColor="#D8E2EC"
                        android:textSize="8.6sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
