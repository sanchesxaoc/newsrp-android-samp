<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingTop="90dp"
            android:paddingEnd="30dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/home_news_badge"
                        android:fontFamily="@font/montserrat_bold"
                        android:letterSpacing="0"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="NEWS RP"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="8.5sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:fontFamily="@font/montserrat_black"
                        android:lineSpacingExtra="1dp"
                        android:maxWidth="520dp"
                        android:text="Comece por aqui"
                        android:textColor="@android:color/white"
                        android:textSize="21sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:maxWidth="620dp"
                        android:text="Servidor ativo, host local e atalhos principais em uma tela simples."
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="9.5sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:background="@drawable/launcher_field_surface_dark"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/home_readiness_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/home_news_badge" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/home_readiness_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Launcher pronto"
                            android:textColor="@android:color/white"
                            android:textSize="9.5sp" />

                        <TextView
                            android:id="@+id/home_readiness_body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Verificando proximo passo"
                            android:textColor="@color/launcher_text_muted"
                            android:textSize="7.5sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="252dp"
                    android:layout_marginEnd="14dp"
                    android:layout_weight="1.08"
                    android:background="@drawable/launcher_hero_panel"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Servidor selecionado"
                            android:textColor="@color/launcher_text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:background="@drawable/launcher_badge_outline"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="JOGO"
                            android:textColor="@color/launcher_text_secondary"
                            android:textSize="7.5sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/selected_server_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/montserrat_black"
                        android:maxLines="1"
                        android:text="Sem servidor ativo"
                        android:textColor="@android:color/white"
                        android:textSize="19sp" />

                    <TextView
                        android:id="@+id/selected_server_address"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="9dp"
                        android:background="@drawable/launcher_field_surface_dark"
                        android:fontFamily="@font/montserrat_medium"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Cadastre um IP em Configuracoes"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/selected_server_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="2"
                        android:text="A lista fica salva no app e o servidor ativo vai para o arquivo do jogo."
                        android:textColor="@color/launcher_text_muted"
                        android:textSize="8.5sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/play_button"
                            android:layout_width="190dp"
                            android:layout_height="48dp"
                            android:background="@drawable/home_play_button"
                            android:fontFamily="@font/montserrat_black"
                            android:letterSpacing="0"
                            android:text="JOGAR"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="13sp" />

                        <Button
                            android:id="@+id/select_server_button"
                            android:layout_width="190dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0"
                            android:text="Trocar servidor"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="10.5sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="252dp"
                    android:layout_weight="0.92"
                    android:background="@drawable/home_panel_surface"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="22dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_black"
                        android:text="Acesso rapido"
                        android:textColor="@android:color/white"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="2"
                        android:text="Abra as areas mais usadas sem procurar no menu."
                        android:textColor="@color/launcher_text_muted"
                        android:textSize="8.5sp" />

                    <LinearLayout
                        android:id="@+id/home_quick_host"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/launcher_stat_tile"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Host local"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Abrir"
                            android:textColor="@color/launcher_success"
                            android:textSize="8.5sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/home_quick_files"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/launcher_stat_tile"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Arquivos"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Gerenciar"
                            android:textColor="@color/launcher_accent_blue"
                            android:textSize="8.5sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/home_quick_settings"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/launcher_stat_tile"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Configuracoes"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Perfil"
                            android:textColor="@color/launcher_accent_gold_bright"
                            android:textSize="8.5sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/home_next_step_button"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:background="@drawable/home_server_select_button"
                        android:fontFamily="@font/montserrat_bold"
                        android:gravity="center"
                        android:text="Proximo passo"
                        android:textColor="@android:color/white"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
