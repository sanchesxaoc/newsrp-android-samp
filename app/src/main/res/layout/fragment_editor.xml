<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="104dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_panel_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/home_news_badge"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="Editor"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="8sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/launcher_badge_outline"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="COMPILADOR PAWN"
                        android:textAllCaps="true"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="7.5sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/montserrat_black"
                    android:text="Editor PAWN"
                    android:textColor="@android:color/white"
                    android:textSize="21sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:maxWidth="760dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:lineSpacingExtra="2dp"
                    android:text="Abra scripts, salve alteracoes e compile .amx direto no Android."
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="9.5sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/home_server_card_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Workspace do editor"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/editor_compiler_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/launcher_console_surface"
                        android:fontFamily="monospace"
                        android:paddingStart="12dp"
                        android:paddingTop="11dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="11dp"
                        android:textColor="#D8E2EC"
                        android:textSize="8.5sp" />

                    <TextView
                        android:id="@+id/editor_current_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="9sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_editor_projects"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_text_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Projetos"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_gamemodes"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Gamemodes"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_includes"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Includes"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_refresh"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Atualizar"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_editor_back"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Voltar"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_root"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Ir p/ projetos"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_import"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Importar"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_new_script"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_text_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Novo .pwn"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_editor_new_include"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_text_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Novo .inc"
                            android:textColor="@android:color/white"
                            android:textSize="8.5sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/home_server_option_default"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Arquivo atual"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/editor_current_file_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/montserrat_bold"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/editor_current_file_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/launcher_console_surface"
                        android:fontFamily="monospace"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp"
                        android:textColor="#D8E2EC"
                        android:textSize="8.5sp" />

                    <EditText
                        android:id="@+id/editor_input"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/launcher_field_surface_dark"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="Abra um .pwn ou .inc para editar aqui."
                        android:inputType="textMultiLine|textCapSentences|textNoSuggestions"
                        android:overScrollMode="ifContentScrolls"
                        android:padding="14dp"
                        android:scrollHorizontally="true"
                        android:textColor="@android:color/white"
                        android:textColorHint="#8EA3B8"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/button_editor_save"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_action_text_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Salvar"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />

                        <TextView
                            android:id="@+id/button_editor_compile"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Compilar .pwn"
                            android:textColor="@android:color/white"
                            android:textSize="8.8sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/home_server_card_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Console do compilador"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/editor_compile_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/launcher_console_surface"
                        android:fontFamily="monospace"
                        android:minHeight="120dp"
                        android:paddingStart="12dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp"
                        android:text="O resultado da compilacao vai aparecer aqui."
                        android:textColor="#D8E2EC"
                        android:textSize="8.8sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/editor_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/launcher_console_surface"
                    android:fontFamily="@font/montserrat_medium"
                    android:padding="16dp"
                    android:text="Esta pasta ainda nao tem scripts ou includes visiveis."
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/editor_files_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
