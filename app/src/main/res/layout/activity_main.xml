<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_app_background"
    android:keepScreenOn="true">

    <LinearLayout
        android:id="@+id/menu_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/launcher_nav_surface"
        android:elevation="14dp"
        android:gravity="start"
        android:orientation="horizontal"
        android:paddingStart="7dp"
        android:paddingTop="7dp"
        android:paddingEnd="7dp"
        android:paddingBottom="7dp"
        android:translationZ="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/nav_item_home"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_home"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Inicio"
                android:padding="10dp"
                android:src="@drawable/ic_home_off" />

            <TextView
                android:id="@+id/nav_label_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Inicio"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_servers"
            android:layout_width="62dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_servers"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Servidores"
                android:padding="10dp"
                android:src="@drawable/ic_servers_off" />

            <TextView
                android:id="@+id/nav_label_servers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Serv."
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_host"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_host"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Host"
                android:padding="10dp"
                android:src="@drawable/ic_host_off" />

            <TextView
                android:id="@+id/nav_label_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Host"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_files"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_files"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Arquivos"
                android:padding="10dp"
                android:src="@drawable/ic_files_off" />

            <TextView
                android:id="@+id/nav_label_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Arquivos"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_editor"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_editor"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Editor"
                android:padding="10dp"
                android:src="@drawable/ic_editor_off" />

            <TextView
                android:id="@+id/nav_label_editor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Editor"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_workbench"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_workbench"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Ferramentas"
                android:padding="10dp"
                android:src="@drawable/ic_tools_off" />

            <TextView
                android:id="@+id/nav_label_workbench"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Tools"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_donate"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_donate"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Loja"
                android:padding="10dp"
                android:src="@drawable/ic_shop_off" />

            <TextView
                android:id="@+id/nav_label_donate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Loja"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_settings"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Config"
                android:padding="10dp"
                android:src="@drawable/ic_settings_off" />

            <TextView
                android:id="@+id/nav_label_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Config"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_item_credits"
            android:layout_width="58dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_credits"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/launcher_nav_button_idle"
                android:contentDescription="Creditos"
                android:padding="10dp"
                android:src="@drawable/ic_credits_off" />

            <TextView
                android:id="@+id/nav_label_credits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/montserrat_bold"
                android:gravity="center"
                android:maxLines="1"
                android:text="Creditos"
                android:textColor="@color/launcher_text_muted"
                android:textSize="7.2sp" />
        </LinearLayout>
    </LinearLayout>

    <com.xyron.game.launcher.util.ViewPagerWithoutSwipe
        android:id="@+id/fragment_place"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
