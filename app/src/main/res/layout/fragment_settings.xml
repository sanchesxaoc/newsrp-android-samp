<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/home_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="92dp"
            android:paddingEnd="28dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/home_panel_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/home_news_badge"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="Config"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="8sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/launcher_badge_outline"
                        android:fontFamily="@font/montserrat_bold"
                        android:paddingStart="10dp"
                        android:paddingTop="5dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="5dp"
                        android:text="PAINEL DO LAUNCHER"
                        android:textAllCaps="true"
                        android:textColor="@color/launcher_text_secondary"
                        android:textSize="7.5sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/montserrat_black"
                    android:text="Configuracoes"
                    android:textColor="@android:color/white"
                    android:textSize="21sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:maxWidth="720dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:lineSpacingExtra="2dp"
                    android:text="Perfil, servidores, teclado e manutencao ficam juntos em um painel claro."
                    android:textColor="@color/launcher_text_secondary"
                    android:textSize="9.5sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/home_server_card_surface"
                        android:gravity="top"
                        android:minHeight="156dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Nome no jogo"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/player_name_value"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/launcher_field_surface_dark"
                            android:ellipsize="end"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Nenhum nome definido"
                            android:textColor="@color/launcher_text_primary"
                            android:textSize="10.5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Esse nick vai para o arquivo do jogo."
                            android:textColor="@color/launcher_text_muted"
                            android:textSize="8.5sp" />

                        <TextView
                            android:id="@+id/button_edit_profile"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/home_server_select_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:minWidth="126dp"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Editar nome"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/home_server_card_surface"
                        android:gravity="top"
                        android:minHeight="156dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Servidores"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Adicione no formato IP:PORTA. Maximo de 5."
                            android:textColor="@color/launcher_text_muted"
                            android:textSize="8.5sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/launcher_console_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:padding="12dp"
                            android:text="Depois de salvar, o IP ja aparece na aba Servidores para selecionar."
                            android:textColor="@color/launcher_text_secondary"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/button_add_server_shortcut"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/home_action_secondary"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:minWidth="146dp"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="Adicionar servidor"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/home_server_card_surface"
                        android:minHeight="144dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Teclado Android"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Ative so se quiser usar o teclado do sistema dentro do jogo."
                            android:textColor="@color/launcher_text_muted"
                            android:textSize="8.5sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/launcher_stat_tile"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Ativar no launcher"
                                android:textColor="@color/launcher_text_primary"
                                android:textSize="9sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/keyboard_switch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textOff=""
                                android:textOn="" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/home_server_card_surface"
                        android:minHeight="144dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Bate-papo"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/montserrat_medium"
                            android:text="Define quantas mensagens ficam visiveis na tela."
                            android:textColor="@color/launcher_text_muted"
                            android:textSize="8.5sp" />

                        <Spinner
                            android:id="@+id/chat_count_select"
                            android:layout_width="136dp"
                            android:layout_height="38dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/style_spinner" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/home_server_card_surface"
                    android:minHeight="112dp"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="VoIP"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Liga ou desliga o microfone/voice chat salvo no settings.ini."
                        android:textColor="@color/launcher_text_muted"
                        android:textSize="8.5sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/launcher_stat_tile"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/montserrat_bold"
                            android:text="Voice chat ativo"
                            android:textColor="@color/launcher_text_primary"
                            android:textSize="9sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/voip_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textOff=""
                            android:textOn="" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/home_server_card_surface"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Manutencao"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:maxWidth="620dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Reinicia o fluxo do launcher e baixa tudo de novo se precisar reabrir a base limpa."
                        android:textColor="@color/launcher_text_muted"
                        android:textSize="8.5sp" />

                    <TextView
                        android:id="@+id/button_reinstall"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/home_action_secondary"
                        android:fontFamily="@font/montserrat_bold"
                        android:gravity="center"
                        android:minWidth="148dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="Reinstalar o jogo"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
