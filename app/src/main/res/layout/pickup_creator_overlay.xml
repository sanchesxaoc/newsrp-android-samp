<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pickup_studio_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pickup_studio_overlay_scrim"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="14dp"
    android:paddingTop="22dp"
    android:paddingEnd="14dp"
    android:paddingBottom="22dp"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:background="@drawable/pickup_studio_panel_surface"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pickup_studio_badge"
                android:fontFamily="@font/montserrat_black"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="COMANDO /CRIARPICKUP"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textSize="8sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/pickup_studio_button_close"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/pickup_studio_secondary_button"
                android:fontFamily="@font/montserrat_black"
                android:gravity="center"
                android:text="X"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/montserrat_black"
            android:text="Pickup Studio"
            android:textColor="@android:color/white"
            android:textSize="22sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/montserrat_medium"
            android:text="Crie, visualize e exporte pickups sem sair do jogo."
            android:textColor="#AFC5E4"
            android:textSize="10sp" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/pickup_studio_card_surface"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Status do estúdio"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/pickup_studio_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="#B7CAE7"
                        android:textSize="9.5sp" />

                    <TextView
                        android:id="@+id/pickup_studio_export_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:textColor="#7FD8FF"
                        android:textSize="8sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/pickup_studio_card_surface"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Configurar pickup"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Salve uma base e use a captura para puxar a posicao atual do player."
                        android:textColor="#A4BAD9"
                        android:textSize="9sp" />

                    <EditText
                        android:id="@+id/pickup_studio_input_label"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/pickup_studio_field_surface"
                        android:fontFamily="@font/montserrat_medium"
                        android:hint="Nome do pickup"
                        android:imeOptions="actionNext"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#6F88AA"
                        android:textSize="10sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/pickup_studio_input_model"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Modelo"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <EditText
                            android:id="@+id/pickup_studio_input_type"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Tipo"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/pickup_studio_input_world"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="World"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <EditText
                            android:id="@+id/pickup_studio_input_interior"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Interior"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/pickup_studio_input_x"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Pos X"
                            android:imeOptions="actionNext"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <EditText
                            android:id="@+id/pickup_studio_input_y"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Pos Y"
                            android:imeOptions="actionNext"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/pickup_studio_input_z"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Pos Z"
                            android:imeOptions="actionNext"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <EditText
                            android:id="@+id/pickup_studio_input_amount"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_field_surface"
                            android:fontFamily="@font/montserrat_medium"
                            android:hint="Valor"
                            android:imeOptions="actionDone"
                            android:inputType="number"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/pickup_studio_button_capture"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_secondary_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Capturar posicao"
                            android:textColor="@android:color/white"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/pickup_studio_button_preview"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_secondary_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Mostrar no jogo"
                            android:textColor="@android:color/white"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/pickup_studio_button_reset"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_secondary_button"
                            android:fontFamily="@font/montserrat_bold"
                            android:gravity="center"
                            android:text="Novo"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/pickup_studio_button_save"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/pickup_studio_primary_button"
                            android:fontFamily="@font/montserrat_black"
                            android:gravity="center"
                            android:text="Salvar pickup"
                            android:textColor="@android:color/white"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/pickup_studio_card_surface"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/montserrat_bold"
                                android:text="Biblioteca de pickups"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/pickup_studio_library_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:fontFamily="@font/montserrat_medium"
                                android:textColor="#9CB3D4"
                                android:textSize="9sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/pickup_studio_button_export_all"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:background="@drawable/pickup_studio_primary_button"
                            android:fontFamily="@font/montserrat_black"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="Exportar lista"
                            android:textColor="@android:color/white"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/pickup_studio_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/pickup_studio_item_surface"
                        android:fontFamily="@font/montserrat_medium"
                        android:gravity="center"
                        android:padding="16dp"
                        android:text="Nenhum pickup salvo ainda."
                        android:textColor="#A6BEDF"
                        android:textSize="9.5sp" />

                    <LinearLayout
                        android:id="@+id/pickup_studio_list_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

</FrameLayout>
