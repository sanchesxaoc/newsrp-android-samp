<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#50101920" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#5EA9B0"
                android:centerColor="@color/launcher_accent_teal"
                android:endColor="@color/launcher_accent_teal_dark" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="#92DAE8EC" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#24EFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="13dp" />
        </shape>
    </item>
</layer-list>
