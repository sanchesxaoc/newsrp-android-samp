<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#4D3A25"
                android:centerColor="#253137"
                android:endColor="#132127" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#68D7B678" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#18FFF6E2"
                android:endColor="#00FFFFFF" />
            <corners android:radius="7dp" />
        </shape>
    </item>
</layer-list>
