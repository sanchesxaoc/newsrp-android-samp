<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/launcher_panel_top"
                android:centerColor="#CD131B23"
                android:endColor="@color/launcher_panel_bottom" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/launcher_border_soft" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#16FFFFFF"
                android:centerColor="#05FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="15dp" />
        </shape>
    </item>
    <item
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#08FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
