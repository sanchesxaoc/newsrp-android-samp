<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF63B7B9"
                android:centerColor="#FF32898C"
                android:endColor="#FF1C555C" />
            <corners android:radius="13dp" />
            <stroke
                android:width="1dp"
                android:color="#FFBEECEF" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#3FEFFFFF"
                android:centerColor="#11FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
