<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#4F1A0E04" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFE2BD79"
                android:centerColor="#FFC98C3C"
                android:endColor="#FF925B28" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="#FFEED6AB" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="14dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#2CFFF4DF"
                android:centerColor="#10FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="13dp" />
        </shape>
    </item>
</layer-list>
